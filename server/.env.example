# Copy to .env and adjust. Used by server/main.py
# Default in code: SQLite file trailsafe.db in the project root (no Docker).
# Optional — MariaDB/MySQL (e.g. after docker compose up -d):
# DATABASE_URL=mysql+pymysql://trailsafe:trailsafe@127.0.0.1:3306/trailsafe
JWT_SECRET=change-me-to-a-long-random-string-in-production
# If 1, forgot-password response includes a reset token (local testing only)
DEMO_REVEAL_RESET_TOKEN=0
